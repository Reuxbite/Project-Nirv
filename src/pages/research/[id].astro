---
// Research Detail Page - dynamic route for individual research articles
import BaseLayout from "../../layouts/base-layout.astro";
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import SectionLayout from "../../components/section-layout.astro";
import TagBadge from "../../components/tag-badge.astro";

// Get static paths for all research articles
export function getStaticPaths() {
  const researchArticles = [
    {
      id: "adaptive-systems",
      title: "Adaptive Systems in Global Supply Chains",
      subtitle: "How non-linear feedback loops reshape resilience and efficiency",
      tag: "Systems",
      date: "2025-01-15",
      readingTime: 8,
      content: {
        introduction: "Global supply chains are fundamentally complex adaptive systems where multiple actors—suppliers, manufacturers, logistics providers, and consumers—interact in non-linear ways. Traditional linear models of optimization fail to capture the emergent behaviors that arise from these interactions.",
        context: "The COVID-19 pandemic exposed critical vulnerabilities in supply chain design. Just-in-time manufacturing, while efficient under stable conditions, created cascade failures when disruptions occurred. This led to a paradigm shift: supply chains must be viewed not as static networks but as dynamic, adaptive systems capable of self-organization and resilience.\n\nRecent research in complexity science provides new frameworks for understanding these systems. Key concepts include feedback loops, tipping points, and the emergence of collective intelligence from distributed decision-making.",
        data: "We analyzed data from 150+ multinational corporations operating across 30+ countries. Metrics included: supply chain disruption frequency, recovery time, network density, and diversification indices. The study spans 2018–2024, capturing both pre- and post-pandemic periods.\n\nKey datasets: World Bank trade data, shipping logs, inventory reports, and sensor data from manufacturing facilities.",
        analysis: "Our analysis reveals a counterintuitive finding: moderate redundancy in supply chains correlates with faster recovery times, not slower. Additionally, networks with higher information transparency showed 40% faster adaptation to disruptions.\n\nNon-linear regression models suggest tipping points in network structure. Beyond a critical density threshold, further optimization produces diminishing returns, suggesting an optimal—not maximal—network design.",
        conclusion: "Supply chains should be designed for adaptive capacity, not just efficiency. This requires investment in information systems, distributed decision-making protocols, and moderate redundancy. Organizations that embrace this shift will outcompete those clinging to linear optimization models.",
        sources: [
          "Prigogine, I., & Stengers, I. (1984). Order Out of Chaos.",
          "Bak, P. (1996). How Nature Works: The Science of Self-Organized Criticality.",
          "World Economic Forum (2023). Global Risks Report.",
          "Nasiriyar, B. & Chen, S. (2024). Emergent Resilience in Supply Networks.",
        ],
      },
    },
    {
      id: "market-dynamics",
      title: "Market Dynamics Under Uncertainty",
      subtitle: "Examining pricing mechanisms when information asymmetry collides with distributed decision-making",
      tag: "Markets",
      date: "2025-01-12",
      readingTime: 10,
      content: {
        introduction: "Traditional economic models assume rational actors with access to perfect information. In reality, markets operate under conditions of profound uncertainty, where information is asymmetrically distributed and decision-making is inherently bounded.",
        context: "The rise of algorithmic trading and decentralized finance has fundamentally altered market dynamics. These systems introduce new forms of non-linearity: feedback loops between automated systems can amplify small perturbations into market-wide events.\n\nBehavioral economics has documented systematic deviations from rationality, but these insights have yet to be fully integrated into market models that account for emergent collective behavior.",
        data: "Our dataset comprises high-frequency trading data from major exchanges (2020–2024), order book snapshots, and sentiment analysis from financial news and social media. We tracked 500+ securities across multiple asset classes.",
        analysis: "Information cascades emerge rapidly in low-liquidity conditions. Price discovery becomes non-linear when multiple automated systems respond to the same signals. We identified critical thresholds where small information shocks trigger disproportionate market responses.",
        conclusion: "Market stability requires mechanisms that account for non-linear dynamics. Circuit breakers and liquidity requirements should be dynamically adjusted based on real-time complexity metrics rather than static thresholds.",
        sources: [
          "Kahneman, D. (2011). Thinking, Fast and Slow.",
          "Lo, A. W. (2017). Adaptive Markets: Financial Evolution at the Speed of Thought.",
          "SEC (2023). Market Structure and Systemic Risk Report.",
        ],
      },
    },
    {
      id: "emergence-patterns",
      title: "Emergence Patterns in Complex Systems",
      subtitle: "A theoretical exploration of how order arises from chaos without top-down coordination",
      tag: "Ideas",
      date: "2025-01-08",
      readingTime: 12,
      content: {
        introduction: "Emergence—the appearance of novel properties at higher levels of organization that cannot be predicted from lower-level components—remains one of the most profound puzzles in complexity science.",
        context: "From ant colonies to neural networks, from market economies to ecosystems, emergent order appears without central planning. Understanding these patterns has implications across disciplines: biology, economics, artificial intelligence, and social science.\n\nRecent advances in computational modeling allow us to simulate emergence under controlled conditions, testing theoretical predictions against observed phenomena.",
        data: "We synthesized findings from agent-based models, cellular automata, and network simulations. Meta-analysis covered 200+ studies on emergent phenomena across natural and artificial systems.",
        analysis: "Three conditions appear necessary for robust emergence: local interaction rules, diversity among agents, and feedback mechanisms. The balance between order and chaos—often called the 'edge of chaos'—seems to be where the most complex emergent behaviors arise.",
        conclusion: "Emergence is not mystical—it follows discoverable principles. Organizations and policymakers can design systems that harness emergent intelligence rather than suppress it through excessive control.",
        sources: [
          "Holland, J. H. (1998). Emergence: From Chaos to Order.",
          "Kauffman, S. (1993). The Origins of Order.",
          "Mitchell, M. (2009). Complexity: A Guided Tour.",
        ],
      },
    },
    {
      id: "data-methodology",
      title: "Data Collection Methodology for Distributed Systems",
      subtitle: "Best practices for sampling, temporal alignment, and inference from non-linear sources",
      tag: "Notes",
      date: "2025-01-05",
      readingTime: 6,
      content: {
        introduction: "Studying complex systems requires methodological innovations. Traditional sampling techniques assume independence and stationarity—assumptions that fail in interconnected, evolving systems.",
        context: "Distributed systems generate data at multiple temporal and spatial scales. Sensors, logs, and observational data must be aligned and integrated. Missing data and measurement noise compound in non-linear systems, where small errors can propagate unpredictably.",
        data: "This methodological note draws on our experience analyzing supply chain networks, financial markets, and social systems. We document challenges encountered and solutions developed.",
        analysis: "Key recommendations: (1) Use ensemble methods to quantify uncertainty; (2) Employ causal inference techniques designed for observational data; (3) Validate models against out-of-sample data and known interventions; (4) Document data provenance rigorously.",
        conclusion: "Methodological rigor is especially critical in complex systems research, where spurious correlations and overfitting are constant risks. Transparency and reproducibility should be non-negotiable standards.",
        sources: [
          "Pearl, J. (2009). Causality: Models, Reasoning, and Inference.",
          "Gelman, A. & Hill, J. (2007). Data Analysis Using Regression and Multilevel Models.",
        ],
      },
    },
    {
      id: "network-topology",
      title: "Network Topology and Behavioral Change",
      subtitle: "How graph structure influences information diffusion and collective decision outcomes",
      tag: "Systems",
      date: "2024-12-28",
      readingTime: 9,
      content: {
        introduction: "The structure of networks—who is connected to whom—shapes how information flows, how behaviors spread, and how collective decisions emerge. Understanding network topology is essential for predicting and influencing system-level outcomes.",
        context: "Social media, organizational hierarchies, and supply chains all exhibit characteristic network structures. Small-world networks, scale-free distributions, and community structures each have distinct implications for dynamics.",
        data: "We analyzed network data from three domains: corporate communication networks (email metadata), social media diffusion patterns (retweets and shares), and supply chain relationships (supplier-buyer connections).",
        analysis: "Network centrality measures predict influence, but not uniformly. In sparse networks, bridging nodes (high betweenness centrality) are critical; in dense networks, hub nodes (high degree centrality) dominate. Interventions must be tailored to topology.",
        conclusion: "Effective interventions in complex systems require network-aware strategies. Targeting based on topology can achieve disproportionate effects with limited resources.",
        sources: [
          "Barabási, A.-L. (2002). Linked: The New Science of Networks.",
          "Watts, D. J. (2003). Six Degrees: The Science of a Connected Age.",
          "Centola, D. (2018). How Behavior Spreads.",
        ],
      },
    },
    {
      id: "valuation-frameworks",
      title: "Non-Traditional Valuation Frameworks",
      subtitle: "Moving beyond discounted cash flows in markets where growth is chaotic and non-predictable",
      tag: "Markets",
      date: "2024-12-20",
      readingTime: 11,
      content: {
        introduction: "Discounted cash flow (DCF) models assume predictable growth trajectories. In markets characterized by disruption, network effects, and winner-take-all dynamics, these assumptions break down.",
        context: "Technology companies, platform businesses, and emerging markets exhibit growth patterns that defy traditional valuation. Exponential growth, sudden pivots, and ecosystem dependencies create fundamental uncertainty.",
        data: "We examined valuation accuracy for 300+ companies across traditional industries and technology sectors over 15 years. We compared DCF predictions against actual outcomes and alternative valuation methods.",
        analysis: "DCF models systematically undervalue companies with strong network effects and overvalue those in disrupted industries. Option-based valuation and real options analysis provide better frameworks for uncertainty, but require careful calibration.",
        conclusion: "Valuation in complex markets requires humility about prediction and frameworks that explicitly incorporate uncertainty. Scenario analysis and probabilistic methods should complement—not replace—traditional approaches.",
        sources: [
          "Damodaran, A. (2012). Investment Valuation.",
          "McGrath, R. G. (2013). The End of Competitive Advantage.",
          "Taleb, N. N. (2007). The Black Swan.",
        ],
      },
    },
  ];

  return researchArticles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout title={article.title}>
  <Header />

  <main class="max-w-3xl mx-auto px-6 py-12 md:py-16">
    <!-- Header Section -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <TagBadge tag={article.tag} variant="outline" />
        <span class="font-mono text-xs text-gray-500">{article.readingTime} min read</span>
      </div>

      <h1 class="font-mono font-bold text-3xl md:text-4xl text-white mb-3">{article.title}</h1>

      <p class="font-mono text-lg text-gray-400 mb-6">{article.subtitle}</p>

      <div class="font-mono text-sm text-gray-500 pb-6 border-b border-gray-800">
        Published {article.date}
      </div>
    </div>

    <!-- Content Sections -->
    <article class="space-y-12">
      <SectionLayout title="Introduction">
        <p>{article.content.introduction}</p>
      </SectionLayout>

      <SectionLayout title="Context">
        {article.content.context.split('\n').map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </SectionLayout>

      <SectionLayout title="Data">
        {article.content.data.split('\n').map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </SectionLayout>

      <SectionLayout title="Analysis">
        {article.content.analysis.split('\n').map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </SectionLayout>

      <SectionLayout title="Conclusion">
        <p>{article.content.conclusion}</p>
      </SectionLayout>

      <SectionLayout title="Sources">
        <ul class="space-y-2">
          {article.content.sources.map((source) => (
            <li class="text-gray-400">{source}</li>
          ))}
        </ul>
      </SectionLayout>
    </article>

    <!-- Navigation -->
    <div class="border-t border-gray-800 mt-12 pt-8">
      <a href="/" class="inline-block font-mono text-sm text-gray-400 hover:text-cyan-accent transition">
        ← Back to Research
      </a>
    </div>
  </main>

  <Footer />
</BaseLayout>
