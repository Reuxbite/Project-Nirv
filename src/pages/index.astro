---
import Layout from "../layouts/Layout.astro";

const title = "Project NIRV – Coming Soon";
const description =
  "A research project mapping how systems really behave. Studies, notes, and non-linear insight are being assembled.";
---

<Layout {title} {description}>
  <section
    style="
      max-width: 720px;
      width: 100%;
      box-sizing: border-box;
      background: radial-gradient(circle at top left, #171b2b 0, #0a0c16 45%, #050611 100%);
      border-radius: 24px;
      padding: 2.4rem 2rem 2.1rem;
      border: 1px solid rgba(134, 144, 255, 0.26);
      box-shadow:
        0 22px 60px rgba(0, 0, 0, 0.85),
        0 0 0 1px rgba(30, 40, 80, 0.65);
      text-align: center;
    "
  >
    <div
      style="
        display:flex;
        justify-content:center;
        align-items:center;
        gap:0.75rem;
        margin-bottom:1.5rem;
        flex-wrap:wrap;
      "
    >
      <div
        style="
          display:inline-flex;
          align-items:center;
          gap:0.45rem;
          padding:0.35rem 0.8rem;
          border-radius:999px;
          background:rgba(7, 9, 18, 0.9);
          border:1px solid rgba(116, 227, 255, 0.4);
          font-size:0.72rem;
          letter-spacing:0.12em;
          text-transform:uppercase;
          color:#c8f9ff;
        "
      >
        <span
          style="
            width:7px;
            height:7px;
            border-radius:50%;
            background:#6fffea;
            box-shadow:0 0 12px #6fffea;
          "
        ></span>
        <span>Project NIRV</span>
      </div>

      <div
        style="
          display:inline-flex;
          align-items:center;
          padding:0.35rem 0.9rem;
          border-radius:999px;
          border:1px solid rgba(142, 130, 255, 0.5);
          font-size:0.72rem;
          letter-spacing:0.16em;
          text-transform:uppercase;
          color:#c6c5ff;
          background:rgba(10, 9, 26, 0.92);
          white-space:nowrap;
        "
      >
        Non-Linear Intelligence Research Vector
      </div>
    </div>

    <h1
      style="
        font-size:2.35rem;
        margin:0 0 0.75rem;
        letter-spacing:0.08em;
        text-transform:uppercase;
      "
    >
      Project NIRV
    </h1>

    <p
      style="
        margin:0 0 1.9rem;
        font-size:0.98rem;
        line-height:1.7;
        color:#d3d5e8;
      "
    >
      A research project mapping how systems really behave. Studies, notes, and
      non-linear insight are being assembled.
    </p>

    <div
      style="
        display:flex;
        flex-direction:column;
        gap:0.45rem;
        font-size:0.86rem;
        color:#a7aac7;
      "
    >
      <span style="font-weight:700; color:#f4f4ff;">
        Coming soon.
      </span>
      <span>
        This space will publish structured, data-backed research as it&apos;s ready.
      </span>
    </div>
  </section>
</Layout>
