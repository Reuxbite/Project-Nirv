---
// Research Card Component - clickable card for research listings
import TagBadge from "./tag-badge.astro";

const { id, title, brief, date, tag } = Astro.props;
---

<a 
  href={`/research/${id}`}
  class="block border border-gray-800 rounded-lg p-6 hover:border-cyan-accent hover:shadow-cyan transition cursor-pointer bg-black group"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h3 class="font-mono font-bold text-base text-white flex-1 group-hover:text-cyan-accent transition">{title}</h3>
    <TagBadge tag={tag} />
  </div>

  <p class="font-mono text-sm text-gray-400 leading-relaxed mb-4 line-clamp-2">{brief}</p>

  <div class="font-mono text-xs text-gray-600">{date}</div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
