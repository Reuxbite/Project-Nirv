---
// Section Layout Component - structured section wrapper for articles
const { title } = Astro.props;
---

<section class="mb-12">
  <h2 class="font-mono font-bold text-xl text-white mb-4 pb-2 border-b border-gray-800">{title}</h2>
  <div class="font-mono text-sm text-gray-300 leading-relaxed space-y-3">
    <slot />
  </div>
</section>
