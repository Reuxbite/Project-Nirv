---
// Filter Tags Component - interactive tag filter (requires client JS)
const { tags, activeTag = null } = Astro.props;
---

<div class="flex flex-wrap gap-3 mb-12" id="filter-container">
  <button
    data-tag="all"
    class={`filter-btn px-4 py-2 font-mono text-xs font-semibold rounded-sm transition ${
      activeTag === null
        ? "bg-cyan-accent text-black"
        : "bg-gray-900 text-white hover:bg-gray-800 border border-gray-800"
    }`}
  >
    All
  </button>
  {tags.map((tag) => (
    <button
      data-tag={tag}
      class={`filter-btn px-4 py-2 font-mono text-xs font-semibold rounded-sm transition ${
        activeTag === tag
          ? "bg-cyan-accent text-black"
          : "bg-gray-900 text-white hover:bg-gray-800 border border-gray-800"
      }`}
    >
      {tag}
    </button>
  ))}
</div>

<script>
  // Client-side filtering logic
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('[data-research-tag]');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-tag');
        
        // Update button styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-cyan-accent', 'text-black');
          b.classList.add('bg-gray-900', 'text-white', 'border', 'border-gray-800');
        });
        btn.classList.remove('bg-gray-900', 'text-white', 'border', 'border-gray-800');
        btn.classList.add('bg-cyan-accent', 'text-black');
        
        // Filter cards
        cards.forEach(card => {
          const cardTag = card.getAttribute('data-research-tag');
          if (tag === 'all' || cardTag === tag) {
            (card as HTMLElement).style.display = 'block';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>
