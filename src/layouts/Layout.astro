---
const {
  title = "Project NIRV",
  description = "A research project mapping how systems really behave. Studies, notes, and non-linear insight.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Space Mono font -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon (make sure these files exist in /public) -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>

  <body
    style="
      margin: 0;
      min-height: 100vh;
      font-family: 'Space Mono', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: radial-gradient(circle at top, #0d101b 0, #05060b 55%, #020308 100%);
      color: #f7f7ff;
      display: flex;
      flex-direction: column;
    "
  >
    <!-- Top bar -->
    <header
      style="
        width: 100%;
        box-sizing: border-box;
        padding: 1.25rem 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      "
    >
      <div style="display:flex; align-items:center; gap:0.6rem;">
        <img
          src="/logo.png"
          alt="Project NIRV logo"	
          width="100"
          height="100"
          style="
            border-radius: 8px;
            background: #0b0e18;
            box-shadow: 0 0 14px rgba(111, 255, 235, 0.5);
            object-fit: cover;
          "
        />
        <span style="font-size: 0.9rem; letter-spacing: 0.12em; text-transform: uppercase; color:#c6c7ff;">
          Project NIRV
        </span>
      </div>

      <nav
        style="
          display:flex;
          gap: 0.9rem;
          font-size: 0.8rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color:#8b8da7;
        "
      >
        <span>Home</span>
        <span style="opacity:0.5;">Research</span>
        <span style="opacity:0.5;">About</span>
      </nav>
    </header>

    <!-- Main content -->
    <main
      style="
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem 3rem;
        box-sizing: border-box;
      "
    >
      <slot />
    </main>

    <!-- Footer -->
    <footer
      style="
        width: 100%;
        box-sizing: border-box;
        padding: 0.85rem 1.75rem 1.4rem;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color:#686a82;
        display:flex;
        justify-content: space-between;
        gap:0.8rem;
      "
    >
      <span>Non-Linear Intelligence Research Vector</span>
      <span>ADV</span>
    </footer>
  </body>
</html>
