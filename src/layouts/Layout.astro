---
const { title = "Project Nirv – Coming Soon" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />
    <!-- if you’re using PNG instead, use this: -->
    <!-- <link rel="icon" type="image/png" href="/favicon.png" /> -->
  </head>

  <body
    style="
      margin: 0;
      min-height: 100vh;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: radial-gradient(circle at top, #141927, #050509 60%);
      color: #f5f5f7;
      display: flex;
      align-items: center;
      justify-content: center;
    "
  >
        <main
      style="
        text-align: center;
        padding: 2.5rem 2rem;
        max-width: 520px;
        border-radius: 18px;
        background: rgba(8,8,14,0.92);
        border: 1px solid rgba(120,120,150,0.35);
        box-shadow: 0 18px 50px rgba(0,0,0,0.6);
        backdrop-filter: blur(16px);
      "
    >
      <img
        src="/logo.png"
        alt="Project Nirv"
        style="width: 72px; height: 72px; margin-bottom: 1.5rem; border-radius: 16px;"
      />
      <div
        style="
          display: inline-flex;
          align-items: center;
          gap: 0.6rem;
          padding: 0.25rem 0.8rem;
          border-radius: 999px;
          border: 1px solid rgba(140,140,170,0.5);
          font-size: 0.75rem;
          text-transform: uppercase;
          letter-spacing: 0.09em;
          color: #c7c7ff;
          margin-bottom: 1.5rem;
        "
      >
        <span
          style="
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #84ffb5;
            box-shadow: 0 0 10px #84ffb5;
          "
        ></span>
        <span>Non-Linear Intelligence Research Vector</span>
      </div>

      <h1
        style="
          font-size: 2.2rem;
          margin: 0 0 0.75rem;
          letter-spacing: 0.03em;
        "
      >
        Project NIRV
      </h1>

      <p
        style="
          margin: 0 0 1.8rem;
          font-size: 0.98rem;
          line-height: 1.7;
          color: #c5c7d5;
        "
      >
        A research project mapping how systems really behave.  
        Studies, notes, and non-linear insight are being assembled.
      </p>

      <div
        style="
          display: inline-flex;
          flex-direction: column;
          gap: 0.35rem;
          font-size: 0.82rem;
          color: #9294aa;
        "
      >
        <span style="font-weight: 600; color: #e4e4ff;">
          Coming soon.
        </span>
        <span>
          This space will publish structured, data-backed research as it’s ready.
        </span>
      </div>
    </main>
  </body>
</html>
